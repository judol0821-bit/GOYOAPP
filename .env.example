VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_VAPID_PUBLIC_KEY=

# Vercel 배포 시 Project Settings > Environment Variables에 위 3개를 등록한 뒤
# Production/Preview/Development 중 필요한 환경을 선택하고 반드시 재배포해야 합니다.

# Spotify 값은 프론트 VITE 환경변수로 노출하지 말 것.
# Supabase Edge Function secrets로만 설정:
# supabase secrets set SPOTIFY_CLIENT_ID=your_spotify_client_id
# supabase secrets set SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Web Push private 값은 프론트 VITE 환경변수로 노출하지 말 것.
# Supabase Edge Function secrets로만 설정:
# npx.cmd supabase secrets set VAPID_PUBLIC_KEY="..." --project-ref skspszkqmkeekhnerfss
# npx.cmd supabase secrets set VAPID_PRIVATE_KEY="..." --project-ref skspszkqmkeekhnerfss
# npx.cmd supabase secrets set VAPID_SUBJECT="mailto:your-email@example.com" --project-ref skspszkqmkeekhnerfss
